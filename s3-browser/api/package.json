{
  "name": "@s3-browser/api",
  "version": "0.0.0",
  "private": true,
  "description": "S3 Browser BFF — implements the Bucket Backend API contract (see designs/mf-integration-plan.md §2.4)",
  "main": "dist/index.js",
  "type": "module",
  "license": "AGPL-3.0-only",
  "scripts": {
    "test": "vitest",
    "test:run": "vitest run",
    "dev": "tsx watch src/index.ts",
    "build": "tsc -p tsconfig.build.json",
    "start": "node dist/index.js",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "typecheck": "tsc --noEmit",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:push": "drizzle-kit push",
    "db:studio": "drizzle-kit studio"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.918.0",
    "@aws-sdk/s3-request-presigner": "^3.918.0",
    "@libsql/client": "^0.17.3",
    "busboy": "^1.6.0",
    "dotenv": "^17.4.2",
    "drizzle-orm": "^0.45.2",
    "express": "^5.2.1",
    "jsonwebtoken": "^9.0.3",
    "morgan": "^1.10.1",
    "pino": "^10.3.1",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/busboy": "^1.5.4",
    "@types/express": "^5.0.6",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/morgan": "^1.9.10",
    "@types/node": "^25.9.1",
    "@types/supertest": "^7.2.0",
    "drizzle-kit": "^0.31.10",
    "eslint": "^10.4.0",
    "eslint-config-prettier": "^10.1.8",
    "globals": "^17.6.0",
    "pino-pretty": "^13.1.3",
    "prettier": "^3.8.3",
    "supertest": "^7.2.2",
    "tsx": "^4.22.3",
    "typescript": "~6.0.3",
    "typescript-eslint": "^8.59.4",
    "vitest": "^4.1.7"
  }
}
