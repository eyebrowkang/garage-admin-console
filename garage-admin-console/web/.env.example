# Module Federation remote — points at the s3-browser frontend's manifest.
# If unset in development, the host derives it from the current browser hostname
# on port 5174, so both localhost and LAN access work once both apps are running.
#
# In Docker/Express-served production, prefer the runtime S3_BROWSER_MF_URL
# variable on @garage-admin/api. Keep this Vite variable as a build-time fallback
# for static hosting that does not serve /runtime-config.js.
VITE_S3_BROWSER_MF_URL=http://localhost:5174/mf-manifest.json
