# Module Federation remote — points at the s3-browser frontend's manifest.
# If unset in development, the host derives it from the current browser
# hostname on port 5174, so both localhost and LAN access work once both
# apps are running.
#
# In production, point this at the deployed s3-browser/web build (e.g.
# https://s3browser.example.com/mf-manifest.json). If unset or unreachable,
# the BucketDetail page falls back gracefully — the rest of the Admin
# Console keeps working.
VITE_S3_BROWSER_MF_URL=http://localhost:5174/mf-manifest.json
