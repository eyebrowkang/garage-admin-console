# JWT secret for authentication tokens (change in production!)
JWT_SECRET="your-secure-jwt-secret-here"

# Encryption key for Garage admin tokens (MUST be exactly 32 bytes)
ENCRYPTION_KEY="01234567890123456789012345678901"

# Server port
PORT=3001

# Admin password for console login
ADMIN_PASSWORD="your-admin-password-here"

# Optional session token lifetimes. The client transparently refreshes a
# short-lived access token using a long-lived refresh token, so users stay
# signed in (e.g. an installed PWA) without re-entering the password. Durations
# are <number><unit> with unit ms|s|m|h|d|w|y. Defaults: access 15m, refresh 14d.
# Global sign-out = rotate JWT_SECRET (stateless tokens can't be revoked one by one).
# ACCESS_TOKEN_TTL="15m"
# REFRESH_TOKEN_TTL="14d"

# System log level (fatal, error, warn, info, debug, trace, silent)
LOG_LEVEL="info"

# HTTP log format for morgan (e.g. dev, combined). Use "off" to disable.
# In production, HTTP logging is disabled by default.
MORGAN_FORMAT="dev"

# Optional runtime Module Federation manifest URL for the embedded S3 Browser.
# When the Admin BFF serves the built frontend, this value is exposed through
# /runtime-config.js so the same Docker image can be reused across deployments.
S3_BROWSER_MF_URL="/s3-browser/mf-manifest.json"

# Optional proxy target for combined Docker Compose deployments. This is a
# container-network URL; browsers keep using S3_BROWSER_MF_URL above.
S3_BROWSER_MF_PROXY_TARGET="http://s3-browser:3002"

# Bucket CORS for browser-direct (large-file) upload/download. By default the BFF
# manages a CORS rule scoped to the requesting app's origin. Pin explicit origins
# (comma-separated) or turn the management off and manage bucket CORS yourself.
# S3_CORS_ALLOWED_ORIGINS="https://your-app.example"
# S3_MANAGE_CORS=true
