{
  "name": "@garage/bucket-api-server",
  "version": "0.0.0",
  "private": true,
  "description": "Shared Express router factory for the Bucket Backend API — used by both BFFs",
  "type": "module",
  "license": "AGPL-3.0-only",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./constants": {
      "types": "./dist/constants.d.ts",
      "import": "./dist/constants.js"
    }
  },
  "files": ["dist"],
  "scripts": {
    "build": "tsc",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "typecheck": "tsc --noEmit",
    "test": "vitest",
    "test:run": "vitest run"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1053.0",
    "@aws-sdk/s3-request-presigner": "^3.1053.0",
    "busboy": "^1.6.0",
    "express": "^5.2.1",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/busboy": "^1.5.4",
    "@types/express": "^5.0.6",
    "@types/node": "^25.9.1",
    "typescript": "~6.0.3",
    "vitest": "^4.1.7"
  }
}
