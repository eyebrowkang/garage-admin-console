# Docker Compose reads .env automatically. Copy this file to .env and replace
# every secret before deploying.

# Start the Admin Console plus the S3 Browser image in static-only remote mode.
# Set this to an empty value for Admin-only deployment.
COMPOSE_PROFILES=s3-browser

GARAGE_ADMIN_HTTP_PORT=3001
GARAGE_ADMIN_JWT_SECRET=change-me-to-a-random-string
GARAGE_ADMIN_ENCRYPTION_KEY=change-me-exactly-32-characters!
GARAGE_ADMIN_PASSWORD=change-me-admin-password

# In combined deployment the browser loads the remote through the Admin entry.
# The proxy target is a Compose-internal URL, not a browser-visible URL.
S3_BROWSER_MF_URL=/s3-browser/mf-manifest.json
S3_BROWSER_MF_PROXY_TARGET=http://s3-browser:3002
S3_BROWSER_STATIC_ONLY=true

# Required only when S3_BROWSER_STATIC_ONLY=false and the S3 Browser image runs
# as the standalone product.
S3_BROWSER_JWT_SECRET=
S3_BROWSER_ENCRYPTION_KEY=
S3_BROWSER_ADMIN_PASSWORD=

LOG_LEVEL=info
MORGAN_FORMAT=off
